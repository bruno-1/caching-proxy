{
  "name": "caching-proxy",
  "description": "HTTP caching proxy server built with TypeScript",
  "license": "ISC",
  "author": "Bruno",
  "type": "module",
  "main": "dist/main/index.js",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start:dev": "tsx --watch src/main/index.ts",
    "build": "tsc",
    "start": "node dist/main/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
