{
  "name": "caching-proxy",
  "description": "HTTP caching proxy server built with TypeScript",
  "license": "ISC",
  "author": "Bruno",
  "type": "module",
  "main": "dist/main/index.js",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start:dev": "tsx --env-file=.env --watch src/main/index.ts",
    "build": "tsc",
    "start": "node  --env-file=.env dist/main/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run __tests__/unit",
    "test:unit:watch": "vitest __tests__/unit",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run __tests__/integration",
    "test:integration:watch": "vitest __tests__/integration",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*": [
      "npm run lint",
      "npm run format"
    ]
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "redis": "^5.12.1",
    "zod": "^4.4.3"
  }
}
